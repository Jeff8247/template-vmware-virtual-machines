# ══════════════════════════════════════════════════════════════════════════════
#  ENVIRONMENT CONFIG — set once per environment, commit and leave alone
# ══════════════════════════════════════════════════════════════════════════════

# ─── vCenter Connection ───────────────────────────────────────────────────────
vsphere_server = "vcenter.corp.example.com"
vsphere_user   = "administrator@vsphere.local"
# vsphere_password = set via TF_VAR_vsphere_password

# ─── Infrastructure Placement ─────────────────────────────────────────────────
datacenter = "MYDC01"
cluster    = "MYCLU01"
datastore  = "MYDS01"
vm_folder  = "VMs/Servers"

# ─── Templates ────────────────────────────────────────────────────────────────
template_name_windows = "template-win2k22-ltsc-64bit-datacenter"
template_name_linux   = "template-ubuntu-22.04-lts"

# ─── Global VM Defaults ───────────────────────────────────────────────────────
# Applied to any VM that does not specify its own value in the vms map.
# firmware, time_zone, and computer_name are set per-OS automatically.

num_cpus = 2
memory   = 4096

disks = [
  { label = "disk0", size = 60, unit_number = 0 }
]

network_interfaces = [
  { network_name = "NET01" }
]

dns_servers     = ["10.0.0.1", "10.0.0.2"]
dns_suffix_list = ["corp.example.com"]
domain          = "corp.example.com"

time_zone_linux   = "Australia/Brisbane"
time_zone_windows = 260

# ─── Global Hardware Defaults ─────────────────────────────────────────────────
hardware_version     = 21
tools_upgrade_policy = "upgradeAtPowerCycle"

# ─── Domain Join ──────────────────────────────────────────────────────────────
# Drives domain join for ALL VMs (Windows via Sysprep, Linux via realm join).
# Remove or null-out windows_domain to deploy workgroup/standalone VMs.

windows_domain         = "corp.example.com"
windows_domain_netbios = "CORP"
windows_domain_user    = "svc-domainjoin@corp.example.com"
# windows_domain_password = set via TF_VAR_windows_domain_password
windows_domain_ou      = "OU=Servers,DC=corp,DC=example,DC=com"

# ─── Windows Credentials ──────────────────────────────────────────────────────
# windows_admin_password = set via TF_VAR_windows_admin_password

# ─── Ansible Post-Provisioning ────────────────────────────────────────────────
# Written to inventory/group_vars/all.yml on every terraform apply.
# See ansible-windows-post-provision/README.md for full documentation.

iso_datastore = "MYDS01"   # datastore holding the payload ISO (defaults to var.datastore if omitted)
iso_folder    = "ISOs/"    # folder within iso_datastore
iso_filename  = "payload-2024.iso"
vlan          = 100        # used to name the NIC: vNIC - VLAN <n>

sccm_management_point = "sccm.corp.example.com"
sccm_site_code        = "A01"

# ansible_windows_user    = "svc-ansible@corp.example.com"   # domain service account (UPN format)
# ansible_winrm_transport = "kerberos"                        # ntlm | kerberos | basic


# ══════════════════════════════════════════════════════════════════════════════
#  VM DEFINITIONS — edit this block for each deployment
# ══════════════════════════════════════════════════════════════════════════════
# Set is_windows = true for Windows VMs, false for Linux.
# Any field omitted falls back to the global defaults above.
# firmware, time_zone, and computer_name are applied automatically per OS.

vms = {

  # ── Windows VM ───────────────────────────────────────────────────────────────

  # Typical Windows VM — just the specs, everything else from globals
  "win-app-01" = {
    is_windows = true
    num_cpus   = 4
    memory     = 8192
    disks = [
      { label = "OS",   size = 100 },
      { label = "Data", size = 50  }
    ]
    ip_settings  = [{ ipv4_address = "10.0.1.101", ipv4_netmask = 24 }]
    ipv4_gateway = "10.0.1.1"
  }

  # Full Windows override — every option available
  "win-app-02" = {
    is_windows    = true
    datacenter    = "MYDC01"
    cluster       = "MYCLU01"
    datastore     = "MYDS01"
    resource_pool = "Resources/AppPool"
    vm_folder     = "VMs/Production"
    computer_name = "WIN-APP-02"           # max 15 chars; auto-truncated from VM name if omitted
    annotation    = "Primary App Server"
    tags          = { "Environment" = "Prod", "Role" = "App" }
    template_name = "template-win2022-gold" # overrides template_name_windows global
    num_cpus      = 8
    memory        = 16384

    scsi_controller_count = 2
    disks = [
      { label = "OS",   size = 150, unit_number = 0  },
      { label = "Data", size = 500, unit_number = 16 }  # Bus 1:0
    ]
    network_interfaces = [{ network_name = "VM Network" }]
    ip_settings        = [{ ipv4_address = "10.0.1.102", ipv4_netmask = 24 }]
    ipv4_gateway       = "10.0.1.1"
    dns_servers        = ["10.0.0.10"]

    windows_domain    = "corp.example.com"
    windows_domain_ou = "OU=AppServers,OU=Servers,DC=corp,DC=example,DC=com"
    windows_run_once  = ["powershell.exe -Command \"Install-WindowsFeature Web-Server\""]
    time_zone_windows = 260
  }

  # ── Linux VM ─────────────────────────────────────────────────────────────────

  # Typical Linux VM — just the specs, everything else from globals
  "lnx-app-01" = {
    is_windows   = false
    num_cpus     = 4
    memory       = 8192
    disks        = [{ label = "OS", size = 100 }, { label = "Data", size = 50 }]
    ip_settings  = [{ ipv4_address = "10.0.2.101", ipv4_netmask = 24 }]
    ipv4_gateway = "10.0.2.1"
  }

  # Full Linux override — every option available
  "lnx-app-02" = {
    is_windows    = false
    datacenter    = "MYDC01"
    cluster       = "MYCLU01"
    resource_pool = "Resources/LinuxPool"
    vm_folder     = "VMs/Production/Linux"
    annotation    = "Linux App Server"
    tags          = { "Environment" = "Prod", "OS" = "Ubuntu" }
    template_name = "template-ubuntu-24.04-lts"  # overrides template_name_linux global
    num_cpus      = 8
    memory        = 16384

    scsi_controller_count = 2
    disks = [
      { label = "OS",   size = 150, unit_number = 0  },
      { label = "Data", size = 200, unit_number = 16 }  # Bus 1:0
    ]
    network_interfaces = [{ network_name = "VM Network" }]
    ip_settings        = [{ ipv4_address = "10.0.2.102", ipv4_netmask = 24 }]
    ipv4_gateway       = "10.0.2.1"
    time_zone_linux    = "Australia/Brisbane"

    linux_script_text = <<-EOT
      cat /etc/os-release
    EOT
  }
}
